{
  "name": "obsidian",
  "editor": {
    "base": "vs-dark",
    "inherit": true,
    "rules": [
      { "token": "comment", "foreground": "5c6370", "fontStyle": "italic" },
      { "token": "keyword", "foreground": "c678dd" },
      { "token": "string", "foreground": "98c379" }
    ],
    "colors": {
      "editor.background": "#0b0b0d",
      "editor.lineHighlightBackground": "#141417",
      "editorCursor.foreground": "#00d4aa",
      "editor.selectionBackground": "#2c313a"
    }
  },
  "ui": {
    "--bg-dark": "#0b0b0d",
    "--bg-panel": "#141417",
    "--bg-sidebar": "#111114",
    "--accent": "#00d4aa",
    "--accent-hover": "#00ffcc",
    "--text-main": "#f5f5f7",
    "--text-muted": "#8b8b99",
    "--border": "rgba(255, 255, 255, 0.05)",
    "--titlebar-bg": "#070708"
  }
}
