{
  "productName": "HyperDrive",
  "version": "1.0.0",
  "identifier": "com.hyperdrive.editor",
  "bundle": {
    "active": true,
    "targets": ["msix", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "CN=Amit, O=HyperDrive, C=IN",
    "copyright": "Copyright © 2026 HyperDrive. All rights reserved.",
    "category": "DeveloperTool",
    "shortDescription": "Ultra-lightweight high performance code editor",
    "longDescription": "HyperDrive is a minimalist, dark-themed code editor optimized for low-end machines. Spawns with under 35MB memory footprints and zero typing latencies.",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["English"],
        "compression": "lzma"
      },
      "msix": {
        "publisher": "CN=Amit, O=HyperDrive, C=IN",
        "publisherDisplayName": "HyperDrive Core Team",
        "displayName": "HyperDrive Code Editor",
        "description": "Ultra-optimized developer editor targeting Web, Python, and Java.",
        "languages": ["en-US"],
        "capabilities": ["runFullTrust"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "HyperDrive",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"
    }
  },
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  }
}
